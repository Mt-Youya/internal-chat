{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": {
        "useMediaCaption": "off",
        "noLabelWithoutControl": "off",
        "noStaticElementInteractions": "info"
      },
      "complexity": {
        "noStaticOnlyClass": "off",
        "noCommaOperator": "off",
        "noImportantStyles": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedImports": "off",
        "noInvalidDirectionInLinearGradient": "info"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      },
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noImplicitAnyLet": "off"
      },
      "style": {
        "useImportType": "error",
        "useTemplate": "off",
        "noNonNullAssertion": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "asNeeded"
    }
  }
}