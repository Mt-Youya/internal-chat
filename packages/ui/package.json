{
  "name": "@chat/ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules",
    "clear": "pnpm -r exec rimraf node_modules"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/roboto": "^5.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@turbo/gen": "^2.8.20",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./src/index.ts",
    "./globals.css": "./src/styles/globals.css",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./Avatar": "./src/components/avatar.tsx"
  }
}
